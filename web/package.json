{
  "name": "thingfactory-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:codegen": "kysely-codegen --dialect sqlite --url ./db/thingfactory.db --out-file lib/db.types.ts",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run db:codegen",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@xyflow/react": "^12.3.0",
    "better-sqlite3": "^11.8.0",
    "kysely": "^0.27.5",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "kysely-codegen": "^0.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0"
  }
}
